# Required at chat runtime. Leave secrets and resource identifiers empty here.
GEMINI_API_KEY=
GEMINI_FILE_SEARCH_STORE=

# Fixed Gemini model and generation limits.
GEMINI_MODEL=gemini-3.5-flash
GEMINI_THINKING_LEVEL=low
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_TEMPERATURE=0.4

# MVP request and conversation guardrails.
MAX_USER_MESSAGE_CHARS=2000
MAX_CONVERSATION_TURNS=12

# Provider timeout, one application retry, and structured-log cost warning.
GEMINI_REQUEST_TIMEOUT_SECONDS=45
GEMINI_MAX_RETRIES=1
COST_WARNING_USD_PER_REQUEST=0.05
