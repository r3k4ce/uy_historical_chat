# Required for Groq chat and Voyage embeddings.
GROQ_API_KEY=
VOYAGE_API_KEY=

# Model, embedding, and generation settings.
CHAT_MODEL=openai/gpt-oss-120b
EMBEDDING_MODEL=voyage-4-large
EMBEDDING_DIMENSIONS=1024
CHAT_MAX_OUTPUT_TOKENS=4096
CHAT_TEMPERATURE=0.6
CHAT_REASONING_EFFORT=medium
CHAT_REQUEST_TIMEOUT_SECONDS=45
CHAT_MAX_RETRIES=1

# The default index path is backend/.chroma/artigas. Set only to override it.
# CHROMA_PERSIST_DIRECTORY=

# Non-default chat models must set both prices explicitly.
# CHAT_INPUT_PRICE_USD_PER_MILLION=
# CHAT_OUTPUT_PRICE_USD_PER_MILLION=

# MVP request and conversation guardrails.
MAX_USER_MESSAGE_CHARS=2000
MAX_CONVERSATION_TURNS=12
COST_WARNING_USD_PER_REQUEST=0.05
